# ═══════════════════════════════════════════════
# КІНО.UA — Environment Variables
# Скопіюйте цей файл як .env.local для розробки
# Для продакшену — встановіть у Vercel/сервері
# ═══════════════════════════════════════════════

# ── TMDB API (ВАЖЛИВО!) ──────────────────────
# Отримайте безплатно на: https://www.themoviedb.org/settings/api
# Потрібен для: пошук фільмів, постери, інформація
NEXT_PUBLIC_TMDB_API_KEY=

# ── App ─────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://kino-ua.vercel.app
NEXT_PUBLIC_APP_NAME=КІНО.UA

# ── Analytics (опціонально) ──────────────────────
# Отримайте на analytics.google.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ── Docker ──────────────────────────────────────
# Встановлюється автоматично при docker build:docker
DOCKER_BUILD=false
PORT=3000
DOMAIN=kino-ua.com

# ── Images ──────────────────────────────────────
# true = вимкнути оптимізацію (для статичного хостингу)
NEXT_PUBLIC_IMAGE_UNOPTIMIZED=false
